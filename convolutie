Descriere: Script Python pentru generarea a două semnale sinusoidale cu parametri
introduși de utilizator, calculul convoluției acestora și vizualizarea grafică.

Surse și resurse utilizate:
- https://numpy.org/doc/2.1/reference/generated/numpy.sin.html
- https://numpy.org/doc/stable/reference/generated/numpy.convolve.html
- https://matplotlib.org/
"""

# Importăm bibliotecile necesare: 
# matplotlib pentru grafice și numpy pentru calcule matematice și vectori
import matplotlib.pyplot as plt
import numpy as np


def genereaza_semnal_sinusoidal(amplitudine, frecventa, faza, t):
    """Generează un semnal sinusoidal pe baza formulei matematice standard."""
    # Formula: A * sin(2 * pi * f * t + faza)
    # np.sin aplică funcția de sinuș pe întregul vector de timp 't' dintr-o singură mișcare
    return amplitudine * np.sin(2 * np.pi * frecventa * t + faza)


def convolueaza_semnale(semnal1, semnal2):
    """Calculează convoluția discretă dintre cele două semnale."""
    # mode='full' înseamnă că se calculează convoluția completă în toate punctele de suprapunere.
    # Dimensiunea rezultatului va fi: len(semnal1) + len(semnal2) - 1
    return np.convolve(semnal1, semnal2, mode='full')


def vizualizeaza_semnale(t, semnal1, semnal2, convolutie, params1, params2):
    """Configurează și afișează interfața grafică cu cele 3 semnale."""
    
    # Deoarece convoluția returnează un vector mai lung, avem nevoie de o nouă axă de timp (t_conv).
    # np.linspace creează puncte egal distanțate de la începutul timpului până la dublul duratei maxime.
    t_conv = np.linspace(t[0], 2 * t[-1], len(convolutie))

    # Creăm o figură mare care conține 3 sub-grafice (subploturi) așezate pe verticală (3 linii, 1 coloană)
    fig, axs = plt.subplots(3, 1, figsize=(12, 9))
    
    # Setăm titlul principal al întregii ferestre grafice
    fig.suptitle('Generator de Semnale Sinusoidale și Convoluție', fontsize=16, fontweight='bold')

    # --- Primul Sub-grafic: Semnalul 1 ---
    # Plotăm timpul pe axa X și valorile semnalului pe axa Y
    axs[0].plot(t, semnal1, color='royalblue', linewidth=1.5, label='Semnal 1')
    # Afișăm dinamic parametrii introduși de utilizator în titlul graficului
    axs[0].set_title(f"Semnal 1 — A={params1['amplitudine']}, f={params1['frecventa']} Hz, φ={params1['faza']:.2f} rad")
    axs[0].set_xlabel('Timp (s)')       # Etichetă axa X
    axs[0].set_ylabel('Amplitudine')  # Etichetă axa Y
    axs[0].grid(True, linestyle='--', alpha=0.6) # Adăugăm un caroiaj (grilă) punctat pe fundal
    axs[0].legend()                     # Afișăm legenda semnalului

    # --- Al doilea Sub-grafic: Semnalul 2 ---
    axs[1].plot(t, semnal2, color='tomato', linewidth=1.5, label='Semnal 2')
    axs[1].set_title(f"Semnal 2 — A={params2['amplitudine']}, f={params2['frecventa']} Hz, φ={params2['faza']:.2f} rad")
    axs[1].set_xlabel('Timp (s)')
    axs[1].set_ylabel('Amplitudine')
    axs[1].grid(True, linestyle='--', alpha=0.6)
    axs[1].legend()

    # --- Al treilea Sub-grafic: Convoluția Rezultată ---
    # Atenție: Aici folosim axa de timp extinsă 't_conv' calculată anterior
    axs[2].plot(t_conv, convolutie, color='mediumseagreen', linewidth=1.5, label='Convoluție (S1 * S2)')
    axs[2].set_title('Convoluția celor două semnale')
    axs[2].set_xlabel('Timp (s)')
    axs[2].set_ylabel('Amplitudine')
    axs[2].grid(True, linestyle='--', alpha=0.6)
    axs[2].legend()

    # Ajustează automat marginile și spațiile dintre grafice ca să nu se suprapună textele
    plt.tight_layout()
    
    # Salvează automat graficul curent ca imagine locală de înaltă rezoluție (dpi=150)
    plt.savefig('semnale_convolutie.png', dpi=150, bbox_inches='tight')
    print("Graficul a fost salvat ca 'semnale_convolutie.png'.")
    
    # Deschide fereastra interactivă pe ecran pentru vizualizare
    plt.show()


def citeste_parametri(nume_semnal):
    """Citește în siguranță parametrii fiecărui semnal, prevenind erorile de tastare."""
    print(f"\n--- Parametrii pentru {nume_semnal} ---")
    while True:
        try:
            # float() convertește textul citit de la tastatură în număr zecimal
            amplitudine = float(input("  Amplitudine (ex: 1.0): "))
            frecventa = float(input("  Frecvență în Hz (ex: 5.0): "))
            faza = float(input("  Fază în radiani (ex: 0.0): "))
            break  # Dacă toate conversiile au reușit, ieșim din bucla infinită
        except ValueError:
            # Dacă utilizatorul introduce litere sau caractere invalide, se declanșează această ramură
            print("  Eroare: Valoare invalidă. Te rog introdu numere.")
            
    # Returnăm parametrii grupați sub formă de dicționar (structură cheie-valoare)
    return {'amplitudine': amplitudine, 'frecventa': frecventa, 'faza': faza}


def citeste_parametri_timp():
    """Citește parametrii axei de timp de la utilizator și generează vectorul temporal."""
    print("\n--- Parametrii axei de timp ---")
    while True:
        try:
            durata = float(input("  Durată totală în secunde (ex: 1.0): "))
            # Pentru numărul de puncte avem nevoie de un număr întreg (int)
            nr_puncte = int(input("  Număr de puncte de eșantionare (ex: 1000): "))
            
            # Validare logică: durata nu poate fi negativă, iar eșantionarea necesită minim 2 puncte
            if durata <= 0 or nr_puncte <= 1:
                print("  Eroare: Durata trebuie să fie > 0 și numărul de puncte > 1.")
                continue # Reia bucla de la început
            break
        except ValueError:
            print("  Eroare: Valoare invalidă. Te rog introdu numere.")
            
    # np.linspace generează vectorul de timp (ex: de la 0 la 1 secundă, împărțit în 1000 de fragmente)
    return np.linspace(0, durata, nr_puncte)


def main():
    """Funcția principală care coordonează execuția întregului program."""
    print("=" * 55)
    print("   Generator de Semnale Sinusoidale cu Convoluție")
    print("=" * 55)

    # Pasul 1: Construim axa de timp globală
    t = citeste_parametri_timp()

    # Pasul 2: Colectăm parametrii de la utilizator pentru ambele semnale
    params1 = citeste_parametri("Semnal 1")
    params2 = citeste_parametri("Semnal 2")

    # Pasul 3: Generăm efectiv valorile discrete (Y) pentru cele două semnale
    semnal1 = genereaza_semnal_sinusoidal(params1['amplitudine'], params1['frecventa'], params1['faza'], t)
    semnal2 = genereaza_semnal_sinusoidal(params2['amplitudine'], params2['frecventa'], params2['faza'], t)

    print("\nSemnalele au fost generate cu succes.")

    # Pasul 4: Calculăm convoluția matematică a semnalelor generate
    convolutie = convolueaza_semnale(semnal1, semnal2)
    print(f"Convoluția a fost calculată. Lungime rezultat: {len(convolutie)} puncte.")

    # Pasul 5: Generăm graficul final și îl salvăm local
    print("\nSe generează graficul...")
    vizualizeaza_semnale(t, semnal1, semnal2, convolutie, params1, params2)


# Această linie se asigură că scriptul rulează doar dacă este pornit direct, 
# nu și dacă este importat ca modul în alt fișier.
if _name_ == "_main_":
    main()
